{
  "manifest_version": 3,
  "name": "YouTube Player Bar Controls",
  "version": "0.1.0",
  "description": "Adds fill screen, playback speed, picture in picture, and copy link controls to the YouTube player bar.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
